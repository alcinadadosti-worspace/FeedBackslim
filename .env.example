# =================================
# Pulse360 - Environment Variables
# =================================

# =================================
# Firebase (Firestore)
# =================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-firebase-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"}'
FIREBASE_STORAGE_BUCKET="your-firebase-project-id.appspot.com"

# =================================
# JWT Secret
# =================================
JWT_SECRET=sua-chave-secreta-muito-forte-mude-em-producao

# =================================
# URLs da Aplicação
# =================================
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# =================================
# Slack Integration (opcional)
# =================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_RH_CHANNEL=rh-notifications

# =================================
# S3 Storage (opcional - para produção)
# =================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
