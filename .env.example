# =================================
# Pulse360 - Environment Variables
# =================================

# Database
POSTGRES_USER=pulse360
POSTGRES_PASSWORD=pulse360secret
POSTGRES_DB=pulse360
DATABASE_URL=postgresql://pulse360:pulse360secret@localhost:5432/pulse360?schema=public

# JWT Secret (generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Slack Integration (optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_RH_CHANNEL=rh-notifications

# S3 Storage (optional - for production file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
