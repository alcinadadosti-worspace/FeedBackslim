{
  "name": "pulse360",
  "version": "1.0.0",
  "description": "Pulse360 - Employee Feedback Platform",
  "scripts": {
    "install:all": "cd app/backend && npm install && cd ../frontend && npm install",
    "build:frontend": "cd app/frontend && npm run build",
    "build:backend": "cd app/backend && npm run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cd app/backend && npm start",
    "dev:backend": "cd app/backend && npm run dev",
    "dev:frontend": "cd app/frontend && npm run dev",
    "db:push": "cd app/backend && npx prisma db push",
    "db:seed": "cd app/backend && npm run db:seed",
    "db:generate": "cd app/backend && npx prisma generate",
    "postinstall": "npm run install:all"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
