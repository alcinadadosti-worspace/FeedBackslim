{
  "name": "ouvidoria",
  "version": "1.0.0",
  "description": "Ouvidoria - Employee Feedback Platform",
  "scripts": {
    "install:backend": "cd app/backend && npm install",
    "install:frontend": "cd app/frontend && npm install",
    "build:backend": "cd app/backend && npm run build",
    "build:frontend": "cd app/frontend && npm run build",
    "copy:static": "node scripts/copy-static.js",
    "build": "npm run build:backend && npm run build:frontend && npm run copy:static",
    "start": "cd app/backend && npm run start:unified",
    "dev:backend": "cd app/backend && npm run dev",
    "dev:frontend": "cd app/frontend && npm run dev",
    "db:seed": "cd app/backend && npm run db:seed",
    "postinstall": "npm run install:backend && npm run install:frontend"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  }
}
